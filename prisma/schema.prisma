generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET
  REWARD
  REFERRAL
  MINING
  FEE
  ADJUSTMENT
  // lowercase aliases used throughout codebase
  deposit
  withdraw
  withdraw_request
  refund
  mining
  stake_lock
  stake_release
  stake_early_release
  daily_bonus
  stake
  stake_payout
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
  // lowercase aliases
  pending
  completed
  failed
  reversed
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELED
  SETTLED
}

enum MatchResult {
  PENDING
  HOME
  AWAY
  DRAW
  CANCELED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String?   @unique
  name         String?
  image        String?
  password     String?
  passwordHash String
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?
  walletBalance Decimal  @default(0) @db.Decimal(30,10)
  lastBonusClaim DateTime?
  loginStreak  Int      @default(0)
  totalBonusEarnings Decimal @default(0) @db.Decimal(30,10)

  wallet                Wallet?
  transactions          Transaction[]
  bets                  Bet[]
  referralsMade         Referral[]       @relation("Referrer")
  referralsGot          Referral[]       @relation("Referred")
  referralRewards       ReferralReward[] @relation("ReferralRewardUser")
  referralRewardSources ReferralReward[] @relation("ReferralRewardSourceUser")
  miningSessions        MiningSession[]
  miningRewards         MiningReward[]
  auditLogs             AuditLog[]
  sessions              Session[]
  accounts              Account[]
  walletTransactions    WalletTransaction[]
  withdrawalRequests    WithdrawalRequest[]
  withdrawalTransactions WithdrawalTransaction[] @relation("WithdrawalTransactionUser")
  miningClaims          MiningClaim[]
  stakings             Staking[]
  crashBets            CrashBet[] @relation("CrashBetUser")

  @@index([email])
  @@index([createdAt])
}

model Wallet {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String        @unique
  balance       Decimal       @default(0) @db.Decimal(30, 10)
  lockedBalance Decimal       @default(0) @db.Decimal(30, 10)
  sofBalance    Decimal       @default(0) @db.Decimal(30, 10)
  usdBalance    Decimal       @default(0) @db.Decimal(30, 10)
  version       Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ledgerEntries LedgerEntry[]

  @@index([userId])
}

model LedgerEntry {
  id            String            @id @default(cuid())
  wallet        Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId      String
  type          TransactionType
  amount        Decimal           @db.Decimal(30, 10)
  balanceBefore Decimal           @db.Decimal(30, 10)
  balanceAfter  Decimal           @db.Decimal(30, 10)
  currency      String?
  source        String?
  reference     String?           @unique
  status        TransactionStatus @default(COMPLETED)
  metadata      Json?
  transaction   Transaction?      @relation("LedgerTransaction", fields: [transactionId], references: [id])
  transactionId String?           @unique
  createdAt     DateTime          @default(now())

  @@index([walletId])
  @@index([createdAt])
}

model Transaction {
  id             String            @id @default(cuid())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  type           TransactionType
  amount         Decimal           @db.Decimal(30, 10)
  status         TransactionStatus @default(PENDING)
  provider       String?
  providerRef    String?
  ledgerEntry    LedgerEntry?      @relation("LedgerTransaction")
  metadata       Json?
  bet            Bet?              @relation("BetTransaction")
  referralReward ReferralReward?   @relation("TransactionReferralReward")
  createdAt      DateTime          @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Match {
  id        String      @id @default(cuid())
  title     String
  odds      Json
  result    MatchResult @default(PENDING)
  settledAt DateTime?
  bets      Bet[]
  createdAt DateTime    @default(now())

  @@index([createdAt])
}

model Bet {
  id            String       @id @default(cuid())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  match         Match?       @relation(fields: [matchId], references: [id])
  matchId       String?
  amount        Decimal      @db.Decimal(30, 10)
  prediction    String
  status        BetStatus    @default(PENDING)
  payout        Decimal      @default(0) @db.Decimal(30, 10)
  fee           Decimal      @default(0) @db.Decimal(30, 10)
  transaction   Transaction? @relation("BetTransaction", fields: [transactionId], references: [id])
  transactionId String?      @unique
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
}

model MiningSession {
  id            String         @id @default(cuid())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  startTime     DateTime       @default(now())
  endTime       DateTime?
  rewardRate    Decimal        @db.Decimal(30, 10)
  metadata      Json?
  miningRewards MiningReward[] @relation("MiningSessionRewards")
  createdAt     DateTime       @default(now())

  @@index([userId])
}

model MiningReward {
  id              String         @id @default(cuid())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  miningSession   MiningSession? @relation("MiningSessionRewards", fields: [miningSessionId], references: [id])
  miningSessionId String?
  amount          Decimal        @db.Decimal(30, 10)
  source          String?
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Referral {
  id         String   @id @default(cuid())
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId String
  referred   User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  referredId String
  createdAt  DateTime @default(now())

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
}

model ReferralReward {
  id            String       @id @default(cuid())
  user          User         @relation("ReferralRewardUser", fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  amount        Decimal      @db.Decimal(30, 10)
  sourceUser    User?        @relation("ReferralRewardSourceUser", fields: [sourceUserId], references: [id])
  sourceUserId  String?
  transaction   Transaction? @relation("TransactionReferralReward", fields: [transactionId], references: [id])
  transactionId String?      @unique
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
}

model WalletTransaction {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       String
  amount     Decimal  @db.Decimal(30,10)
  status     String
  reference  String?  @unique
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model WithdrawalRequest {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  amountSof  Decimal  @db.Decimal(30,10)
  amountUsd  Decimal  @db.Decimal(30,10)
  status     String
  reference  String?
  adminId    String?
  processedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model MiningClaim {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  amountSof        Decimal  @db.Decimal(30,10)
  claimedAt        DateTime @default(now())
  streakDay        Int
  deviceFingerprint String?

  @@index([userId])
  @@index([claimedAt])
}

model Staking {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  amount         Decimal  @db.Decimal(30,10)
  periodDays     Int
  stakePlan      String
  startAt        DateTime
  endAt          DateTime
  reward         Decimal  @db.Decimal(30,10)
  payoutAmount   Decimal  @db.Decimal(30,10)
  status         String
  penaltyApplied Boolean  @default(false)
  claimedAt      DateTime?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  expires      DateTime

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  ip        String?
  meta      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ip])
}

model GameRound {
  id            String      @id @default(cuid())
  gameType      String      @default("crash") // crash, dice, flip, wheel
  status        String      @default("active") // active, crashed, settled
  multiplier    Decimal     @default(1) @db.Decimal(10, 2)
  crashPoint    Decimal?    @db.Decimal(10, 2) // where the game crashed
  startedAt     DateTime    @default(now())
  crashedAt     DateTime?
  settledAt     DateTime?
  provablyFairSeed String?
  bets          CrashBet[]
  totalWagers   Decimal     @default(0) @db.Decimal(30, 10)
  totalPayouts  Decimal     @default(0) @db.Decimal(30, 10)
  createdAt     DateTime    @default(now())

  @@index([gameType])
  @@index([status])
  @@index([createdAt])
}

model CrashBet {
  id              String      @id @default(cuid())
  gameRound       GameRound   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId         String
  user            User        @relation("CrashBetUser", fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  betAmount       Decimal     @db.Decimal(30, 10)
  autoCashout     Decimal?    @db.Decimal(10, 2) // multiplier to auto cashout at
  manualCashout   Decimal?    @db.Decimal(10, 2) // multiplier user manually cashed out at
  status          String      @default("active") // active, won, lost, cashed_out, uncashed
  payout          Decimal     @default(0) @db.Decimal(30, 10)
  winAmount       Decimal     @default(0) @db.Decimal(30, 10)
  walletLocked    Decimal     @db.Decimal(30, 10) // amount locked from wallet during bet
  lockedTransaction String?   // reference to wallet lock transaction
  createdAt       DateTime    @default(now())
  cashedOutAt     DateTime?
  settledAt       DateTime?

  @@index([userId])
  @@index([roundId])
  @@index([status])
  @@index([createdAt])
}

model GameHistory {
  id            String    @id @default(cuid())
  userId        String
  gameType      String
  roundId       String
  betAmount     Decimal   @db.Decimal(30, 10)
  payout        Decimal   @db.Decimal(30, 10)
  winAmount     Decimal   @db.Decimal(30, 10)
  multiplier    Decimal   @db.Decimal(10, 2)
  status        String
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([gameType])
  @@index([createdAt])
}

model WithdrawalTransaction {
  id                String   @id @default(cuid())
  user              User     @relation("WithdrawalTransactionUser", fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  amountRequested   Decimal  @db.Decimal(30, 10)
  amountProcessed   Decimal  @db.Decimal(30, 10)
  fee               Decimal  @default(0) @db.Decimal(30, 10)
  method            String   // bank_transfer, crypto, paystack
  status            String   @default("pending") // pending, processing, completed, failed
  reference         String?  @unique
  bankDetails       Json?    // for bank transfers
  metadata          Json?
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
